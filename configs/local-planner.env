# Local-model planner config for the CapableDeputy daemon.
# Source this file before `capdep daemon start` to pin the planner
# (and optionally the quarantined extractor) to a local Ollama model.
#
# See docs/local-model-planner.md for the full rationale.

# Planner — the privileged LLM the agent loop drives.
# LiteLLM supports any model exposed by your local Ollama install.
export CAPDEP_LLM_MODEL="ollama/llama3.1:70b"

# Quarantined extractor — sees labeled data; produces schema output.
# Comment out to reuse CAPDEP_LLM_MODEL.
export CAPDEP_QUARANTINED_LLM_MODEL="ollama/phi3:mini"

# Optional: directory of SKILL.md files to register as labeled tools
# at daemon startup. Each skill becomes a tool whose handler calls the
# quarantined LLM with the skill's prompt body.
# export CAPDEP_SKILLS_DIR="$HOME/.config/capabledeputy/skills"
